        </w:rPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>1. プロジェクト基本情報</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="50B025F1" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="1"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>名称</w:t>
      </w:r>
      <w:r>
        <w:t>: CHRO-Strategic-Insight-Engine (CHRO-SIE)</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="10AC7608" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="1"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>ディレクトリ</w:t>
      </w:r>
      <w:r>
        <w:t>: C:\Users\hashi\Documents\CHRO-Strategic-Insight-Engine</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="4338BE76" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="1"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>目標</w:t>
      </w:r>
      <w:r>
        <w:t>: 対象企業のCHRO（または人事担当役員）のSNSアカウント（X, LinkedIn）を特定し、マスタリストを作成する。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="72EF9F7D" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>2. 実行上の絶対ルール（フェーズゲート）</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="6DC66A74" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>重要</w:t>
      </w:r>
      <w:r>
        <w:t>: 今回は「リスト化」までの工程を完了させた時点で作業を一旦停止し、ユーザー（私）に報告すること。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="6FEEE1A5" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="2"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>取得できたアカウントの数や質を私が確認し、次フェーズ（データ収集・分析）に進む判断を下す。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="3A535A5F" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="2"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>勝手にデータ収集（API実行や大規模スクレイピング）を開始しないこと。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="2ABEC9DA" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>3. 調査対象とロジック (Researcher Agent)</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="745273C7" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:r>
        <w:t>以下の優先順位とルールに従って、340社のアカウント特定を行うこと。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="1A30935B" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>A. 対象企業群</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="5491B97D" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="3"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>JP</w:t>
      </w:r>
      <w:r>
        <w:t>: TOPIX100 構成銘柄</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="7585C96C" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="3"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>US</w:t>
      </w:r>
      <w:r>
        <w:t>: S&amp;P100 構成銘柄</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="288D2C59" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="3"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>UK</w:t>
      </w:r>
      <w:r>
        <w:t>: FTSE100 構成銘柄</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="4AEB0C67" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="3"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>DE</w:t>
      </w:r>
      <w:r>
        <w:t>: DAX40 構成銘柄</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="36479C7E" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>B. 人物特定ルール</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="744B55C7" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="4"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>役職名に「CHRO」を含む人物を最優先で探す。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="0926A27D" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="4"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>日本企業でCHROが不在の場合は、「人事担当役員」または「人事を管轄する取締役」を第2候補として探す 。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="2A345E2B" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="4"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>スキップ条件</w:t>
      </w:r>
      <w:r>
        <w:t>: 10分程度の検索で当該人物のXまたはLinkedInアカウントが特定できない場合、その企業は「特定不可」としてログに残し、深追いせずに次の企業へ進むこと。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="360D5969" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>C. SNS情報取得の技術的手法（指示）</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="392BD70E" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:r>
        <w:t>以下のツール・スキルを活用して情報を探ること。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="61E5F99E" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="5"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>X (Twitter)</w:t>
      </w:r>
      <w:r>
        <w:t>: last30daysスキルを用いて、企業名＋氏名＋「CHRO」などのキーワードで検索し、本人のアカウント（認証済み、またはフォロワー等から本人と断定できるもの）を特定。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="4EA611D1" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="5"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>LinkedIn</w:t>
      </w:r>
      <w:r>
        <w:t>: Claude Codeの「Browser Use」または「Google Search MCP」を活用し、氏名・所属・役職からプロフィールURLを特定。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="54065C96" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="5"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>ノイズ除外</w:t>
      </w:r>
      <w:r>
        <w:t>: 本人と確証が持てないアカウント（同姓同名の別人等）はリストに含めない。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="131AC248" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>4. 期待するアウトプット (Phase 1)</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="049C0B31" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:r>
        <w:lastRenderedPageBreak/>
        <w:t>ディレクトリ内に master_list.csv を作成し、以下の項目を整理せよ。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="716611C4" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="6"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>企業名 (Index名含む)</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="73C48A88" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="6"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>国</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="560366D6" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="6"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>氏名</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="5B8CFB14" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="6"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>役職（CHRO or その他）</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="4A891837" w14:textId="77777777" w:rsidR="003A60B4" w:rsidRPr="003A60B4" w:rsidRDefault="003A60B4" w:rsidP="003A60B4">
