        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>ワードクラウド</w:t>
      </w:r>
      <w:r>
        <w:t>: 頻出キーワードの可視化。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="503A6451" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="1"/>
          <w:numId w:val="4"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>役割分析</w:t>
      </w:r>
      <w:r>
        <w:t xml:space="preserve">: 「現状の労務管理中心の姿」と「経営パートナー・AIワークフォースアーキテクトとしての在るべき姿」を対比させ、JPと海外の差分をフラットに抽出。 </w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="6B275D1A" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>④ 戦略立案：ideate_business_strategy</w:t>
      </w:r>
      
      
      
    </w:p>
    <w:p w14:paraId="602B9AF1" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="5"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>ロジック</w:t>
      </w:r>
      <w:r>
        <w:t>: 分析結果を基に、人事・ガバナンス・テクノロジー（人事/ガバナンス関連）領域で広くビジネスアイデアを企画。事業戦略との掛け算や、企業価値向上に直結する示唆を出すこと。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="03E3E9FE" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>⑤ レポート作成：produce_report</w:t>
      </w:r>
      
      
      
    </w:p>
    <w:p w14:paraId="599471F7" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="6"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>構成</w:t>
      </w:r>
      <w:r>
        <w:t>: 以下の2章構成でMarkdown/PDF出力。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="2EE4EF84" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="1"/>
          <w:numId w:val="6"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>第1章：CHROトレンド分析（yyyy/mm）</w:t>
      </w:r>
      
      
      
      
      <w:r>
        <w:t>:</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="1FC56C2D" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="2"/>
          <w:numId w:val="6"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>サマリーと詳細。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="73D3D04A" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="2"/>
          <w:numId w:val="6"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>客観事実 (Fact)</w:t>
      </w:r>
      <w:r>
        <w:t>: 統計や具体例。「〜という事実がある」と記述。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="1FEA8DD6" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="2"/>
          <w:numId w:val="6"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>鋭い示唆 (Insight)</w:t>
      </w:r>
      <w:r>
        <w:t>: コンサルタント視点の提言。「〜すべきである」と記述。両者を明確にセクション分けすること。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="04501467" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="1"/>
          <w:numId w:val="6"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>第2章：ビジネスインサイト</w:t>
      </w:r>
      <w:r>
        <w:t>: 戦略立案官によるビジネスアイデアの提案。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="0F2B55BD" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>3. 定期メンテナンスサイクル (Scheduled Maintenance)</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="0C84EE7B" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:r>
        <w:t>スーパーバイザーに以下の定期タスクを組み込むこと。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="62BDAEB6" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="7"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>リスト更新</w:t>
      </w:r>
      <w:r>
        <w:t>: 1, 4, 7, 10, 11月の第1営業日に update_master_list を実行し、指名指数（TOPIX100等）の顔ぶれやCHROの交代を確認。</w:t>
      </w:r>
      
      
      
      
    </w:p>
    <w:p w14:paraId="21E467A4" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="7"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>月次レポート</w:t>
      </w:r>
      <w:r>
        <w:t>: 毎月第2営業日に①〜⑤を連続実行。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="5268CB27" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>4. スーパーバイザーの挙動設定</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="19468970" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="8"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>あなた（ユーザー）との唯一の窓口として機能。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="4213413D" w14:textId="77777777" w:rsidR="00844160" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="8"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>各エージェント（調査・整理・分析・立案・執筆）に仕事を振り、進捗を管理。</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="391F1D59" w14:textId="6A127167" w:rsidR="00D80A01" w:rsidRPr="00844160" w:rsidRDefault="00844160" w:rsidP="00844160">
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="8"/>
        </w:numPr>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:bCs/>
        </w:rPr>
        <w:t>「あやふやに進まない」</w:t>
      </w:r>
      <w:r>
        <w:t>: LinkedInの認証切れ、APIエラー、想定外の投稿パターンの発生時には、直ちにあなたに報告し、指示を仰ぐこと。</w:t>
      </w:r>
    </w:p>
